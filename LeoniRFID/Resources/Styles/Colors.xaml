<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── LEONI Brand Colors ─────────────────────────────────────────── -->
    <Color x:Key="LeoniDarkBlue">#00205B</Color>
    <Color x:Key="LeoniMidBlue">#003087</Color>
    <Color x:Key="LeoniLightBlue">#004BC1</Color>
    <Color x:Key="LeoniOrange">#E8490F</Color>
    <Color x:Key="LeoniOrangeDark">#C23A0A</Color>
    <Color x:Key="LeoniWhite">#FFFFFF</Color>
    <Color x:Key="LeoniGrayLight">#F2F4F8</Color>
    <Color x:Key="LeoniGrayMid">#8A909A</Color>
    <Color x:Key="LeoniGrayDark">#4A4F54</Color>
    <Color x:Key="LeoniBlack">#0D0D0D</Color>

    <!-- ── Background ────────────────────────────────────────────────── -->
    <Color x:Key="PageBackground">#F2F4F8</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="CardBackgroundAlt">#FFFFFF</Color>
    <Color x:Key="SurfaceBackground">#FFFFFF</Color>

    <!-- ── Text ──────────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimary">#00205B</Color>
    <Color x:Key="TextSecondary">#4A4F54</Color>
    <Color x:Key="TextMuted">#8A909A</Color>
    <Color x:Key="TextAccent">#E8490F</Color>

    <!-- ── Status Colors ──────────────────────────────────────────────── -->
    <Color x:Key="StatusInstalled">#10B981</Color>
    <Color x:Key="StatusRemoved">#EF4444</Color>
    <Color x:Key="StatusMaintenance">#F59E0B</Color>

    <!-- ── Interactive ────────────────────────────────────────────────── -->
    <Color x:Key="ButtonPrimary">#E8490F</Color>
    <Color x:Key="ButtonPrimaryHover">#C23A0A</Color>
    <Color x:Key="ButtonSecondary">#FFFFFF</Color>
    <Color x:Key="InputBackground">#FFFFFF</Color>
    <Color x:Key="InputBorder">#CBD5E1</Color>
    <Color x:Key="InputBorderFocus">#004BC1</Color>
    <Color x:Key="DividerColor">#E2E8F0</Color>

</ResourceDictionary>
