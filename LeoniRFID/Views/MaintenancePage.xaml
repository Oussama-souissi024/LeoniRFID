<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.MaintenancePage"
             x:DataType="vm:MaintenanceViewModel"
             Title="🔧 Maintenance">

    <Grid RowDefinitions="*">

        <!-- ═══ VUE LISTE : Machines en panne + en maintenance ═══ -->
        <ScrollView IsVisible="{Binding ShowDetail, Converter={StaticResource InverseBool}}">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Titre + compteurs -->
                <Frame Style="{StaticResource Card}" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🔧 Tableau Maintenance" Style="{StaticResource HeadingLabel}" FontSize="20" />
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Frame Style="{StaticResource CardAlt}" Padding="12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="{Binding BrokenCount}" TextColor="#E74C3C" FontSize="28" 
                                           FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                                    <Label Text="🔴 En Panne" FontSize="11" HorizontalTextAlignment="Center" 
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Frame>
                            <Frame Grid.Column="1" Style="{StaticResource CardAlt}" Padding="12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="{Binding InMaintenanceCount}" TextColor="#F39C12" FontSize="28" 
                                           FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                                    <Label Text="🔧 En Cours" FontSize="11" HorizontalTextAlignment="Center" 
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section : Machines en maintenance (prioritaire) -->
                <CollectionView ItemsSource="{Binding InMaintenanceMachines}">
                    <CollectionView.Header>
                        <Label Text="⏱️ Maintenance en cours" Style="{StaticResource HeadingLabel}" FontSize="16" Margin="0,0,0,5" />
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Machine">
                            <Frame Style="{StaticResource CardAlt}" Margin="0,4" Padding="15"
                                   BorderColor="#F39C12">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceViewModel}}, Path=SelectMachineCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">
                                    <Label Text="{Binding Name}" FontFamily="RobotoBold" FontSize="15" />
                                    <Label Grid.Column="1" Text="🔧 En cours ▶" TextColor="#F39C12" 
                                           FontFamily="RobotoBold" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="15">
                                        <Label Text="{Binding Department}" FontSize="12" 
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding TagId, StringFormat='🏷️ {0}'}" FontSize="12" 
                                               TextColor="{StaticResource TextMuted}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Section : Machines en panne (à traiter) -->
                <CollectionView ItemsSource="{Binding BrokenMachines}">
                    <CollectionView.Header>
                        <Label Text="🔴 Machines en panne — À traiter" Style="{StaticResource HeadingLabel}" FontSize="16" Margin="0,5,0,5" />
                    </CollectionView.Header>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="30" Spacing="10">
                            <Label Text="🎉" FontSize="48" HorizontalTextAlignment="Center" />
                            <Label Text="Aucune machine en panne !" 
                                   Style="{StaticResource SubHeadingLabel}" 
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Machine">
                            <Frame Style="{StaticResource CardAlt}" Margin="0,4" Padding="15"
                                   BorderColor="#E74C3C">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MaintenanceViewModel}}, Path=SelectMachineCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">
                                    <Label Text="{Binding Name}" FontFamily="RobotoBold" FontSize="15" />
                                    <Label Grid.Column="1" Text="🔴 En panne ▶" TextColor="#E74C3C" 
                                           FontFamily="RobotoBold" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="15">
                                        <Label Text="{Binding Department}" FontSize="12" 
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding TagId, StringFormat='🏷️ {0}'}" FontSize="12" 
                                               TextColor="{StaticResource TextMuted}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ VUE DÉTAIL : Machine sélectionnée + Actions ═══ -->
        <ScrollView IsVisible="{Binding ShowDetail}">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Bouton retour -->
                <Button Text="← Retour à la liste" 
                        Command="{Binding BackToListCommand}"
                        Style="{StaticResource SecondaryButton}" 
                        HorizontalOptions="Start" HeightRequest="40" />

                <!-- Carte machine -->
                <Frame Style="{StaticResource Card}" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{Binding SelectedMachine.Name}" 
                               Style="{StaticResource HeadingLabel}" FontSize="22" />
                        <BoxView Style="{StaticResource Divider}" />
                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto" 
                              ColumnSpacing="15" RowSpacing="8">
                            <Label Text="🏷️ Tag EPC" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Column="1" Text="{Binding SelectedMachine.TagId}" 
                                   FontFamily="RobotoBold" FontSize="13" />
                            <Label Grid.Row="1" Text="🏭 Département" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMachine.Department}" 
                                   FontFamily="RobotoBold" FontSize="13" />
                            <Label Grid.Row="2" Text="📊 Statut" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding SelectedMachine.StatusDisplay}" 
                                   FontFamily="RobotoBold" FontSize="13" />
                            <Label Grid.Row="3" Text="📅 Installation" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMachine.InstallationDateDisplay}" 
                                   FontFamily="RobotoBold" FontSize="13" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Chronomètre de maintenance -->
                <Frame Style="{StaticResource Card}" Padding="20" IsVisible="{Binding IsMaintenanceActive}"
                       BorderColor="#F39C12">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="⏱️ MAINTENANCE EN COURS" 
                               TextColor="#F39C12" FontFamily="RobotoBold" FontSize="14" 
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding MaintenanceTimer}" 
                               TextColor="{StaticResource TextPrimary}" FontFamily="RobotoBold" FontSize="48" 
                               HorizontalTextAlignment="Center" />
                        <Label Text="Durée écoulée depuis le début de l'intervention" 
                               TextColor="{StaticResource TextMuted}" FontSize="11" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Bouton : Commencer la maintenance (si Broken) -->
                <Button Text="🔧 COMMENCER LA MAINTENANCE"
                        Command="{Binding StartMaintenanceCommand}"
                        BackgroundColor="#F39C12" TextColor="White"
                        HeightRequest="55" CornerRadius="12" FontAttributes="Bold" FontSize="16"
                        IsVisible="{Binding CanStartMaintenance}" />

                <!-- Bouton : Terminer la maintenance (si InMaintenance) -->
                <Button Text="✅ TERMINER LA MAINTENANCE"
                        Command="{Binding EndMaintenanceCommand}"
                        BackgroundColor="#27AE60" TextColor="White"
                        HeightRequest="55" CornerRadius="12" FontAttributes="Bold" FontSize="16"
                        IsVisible="{Binding IsMaintenanceActive}" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay -->
        <Grid BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="True" VerticalOptions="Center" Color="White" />
        </Grid>

    </Grid>
</ContentPage>
