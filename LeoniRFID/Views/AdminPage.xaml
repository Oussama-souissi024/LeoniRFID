<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.AdminPage"
             x:DataType="vm:AdminViewModel"
             x:Name="adminPage"
             Title="Pro Administration">

    <!-- 🎓 Pédagogie PFE : Layout en Grille (Grid)
         RowDefinitions="Auto, *" signifie que la première ligne (Header) 
         prend exactement la hauteur de son contenu (Auto), 
         et la deuxième ligne (CollectionView) prend TOUT l'espace restant (*). -->
    <Grid RowDefinitions="Auto, *">
        
        <!-- Header Actions -->
        <Border Grid.Row="0" Background="{StaticResource BlueGradient}" Margin="10" Padding="15" StrokeThickness="0" StrokeShape="RoundRectangle 10">
            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Button Text="IMPORT EXCEL" Command="{Binding ImportExcelCommand}" Style="{StaticResource PrimaryButton}" HeightRequest="44" Padding="20,0" />
                <Button Text="EXCEL TEMPLATE" Command="{Binding GenerateSampleExcelCommand}" Style="{StaticResource SecondaryButton}" HeightRequest="44" Padding="20,0" />
            </HorizontalStackLayout>
        </Border>

        <!-- Machine List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Machines}" Margin="10,0">
            <CollectionView.Header>
                <Label Text="Machine Inventory" Style="{StaticResource HeadingLabel}" Margin="5,10" FontSize="16" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Machine">
                    <Border Style="{StaticResource InteractiveBorderCard}" Margin="0,5" Padding="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding StandardEquipmentName}" FontFamily="RobotoBold" FontSize="15" />
                                <Label Text="{Binding TagReference}" Style="{StaticResource CaptionLabel}" />
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Plant}" FontSize="11" TextColor="{StaticResource LeoniOrange}" />
                                    <Label Text="•" TextColor="{StaticResource TextMuted}" />
                                    <Label Text="{Binding StatusDisplay}" FontSize="11" TextColor="{Binding EquipmentStatus, Converter={StaticResource StatusToColor}}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <ImageButton Source="edit_icon.png" Command="{Binding BindingContext.EditMachineCommand, Source={x:Reference adminPage}}" CommandParameter="{Binding .}" WidthRequest="32" HeightRequest="32" x:DataType="{x:Null}" />
                                <ImageButton Source="delete_icon.png" Command="{Binding BindingContext.DeleteMachineCommand, Source={x:Reference adminPage}}" CommandParameter="{Binding .}" WidthRequest="32" HeightRequest="32" x:DataType="{x:Null}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="True" Color="White" />
                <Label Text="{Binding ImportStatus}" TextColor="White" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
