<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             x:Class="LeoniRFID.Views.ScanPage"
             x:DataType="vm:ScanViewModel"
             Title="Scanner RFID">

    <!-- 🎓 Pédagogie PFE : Layout en Grille (Grid)
         La page est découpée en 3 rangées :
         Row 0 (Auto) = Barre de statut + saisie manuelle EPC
         Row 1 (*)    = Zone centrale (animation de scan / résultat)
         Row 2 (Auto) = Boutons d'action en bas (Installer / Retirer / Maintenance) -->
    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="20">

        <!-- Top Status & Manual Entry -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Label Text="{Binding ScanStatusText}" 
                   Style="{StaticResource SubHeadingLabel}" 
                   HorizontalTextAlignment="Center"
                   TextColor="{Binding TagNotFound, Converter={StaticResource StatusToColor}}" />

            <Frame Style="{StaticResource CardAlt}" Padding="0" HeightRequest="50">
                <Grid ColumnDefinitions="*, Auto">
                    <Entry Placeholder="Saisie manuelle EPC..." 
                           Text="{Binding ManualEpc}"
                           Style="{StaticResource ModernEntry}"
                           Margin="10,0" />
                    <Button Grid.Column="1" Text="OK" Command="{Binding ManualScanCommand}" 
                            BackgroundColor="{StaticResource LeoniMidBlue}" CornerRadius="0" WidthRequest="60" />
                </Grid>
            </Frame>
        </VerticalStackLayout>

        <!-- Result / Animation Area -->
        <Grid Grid.Row="1" VerticalOptions="Center">
            
            <!-- Scanning Animation (Placeholder) -->
            <VerticalStackLayout IsVisible="{Binding IsScanning}" Spacing="20" VerticalOptions="Center">
                <ActivityIndicator IsRunning="True" HeightRequest="100" WidthRequest="100" Color="{StaticResource LeoniOrange}" />
                <Label Text="En attente de tag RFID..." Style="{StaticResource BodyLabel}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Scanned Machine Result -->
            <Frame IsVisible="{Binding HasMachine}" Style="{StaticResource Card}" VerticalOptions="Center" Padding="25">
                <VerticalStackLayout Spacing="15">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="EPC:" Style="{StaticResource CaptionLabel}" VerticalOptions="Center" />
                        <Label Text="{Binding ScannedEpc}" Style="{StaticResource BodyLabel}" FontFamily="RobotoBold" />
                    </HorizontalStackLayout>
                    
                    <BoxView Style="{StaticResource Divider}" />

                    <Label Text="{Binding FoundMachine.Name}" Style="{StaticResource HeadingLabel}" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding FoundMachine.Department}" Style="{StaticResource SubHeadingLabel}" HorizontalTextAlignment="Center" />
                    
                    <Frame BackgroundColor="{Binding FoundMachine.Status, Converter={StaticResource StatusToBadge}}" 
                           Padding="10,5" CornerRadius="5" HorizontalOptions="Center" HasShadow="False">
                        <Label Text="{Binding FoundMachine.StatusDisplay}" TextColor="White" FontFamily="RobotoBold" />
                    </Frame>

                    <Button Text="Voir détails complets" 
                            Style="{StaticResource SecondaryButton}" 
                            Command="{Binding ViewDetailCommand}" 
                            Margin="0,15,0,0" />
                </VerticalStackLayout>
            </Frame>

            <!-- 🎓 Tag inconnu → Formulaire d'enregistrement nouvelle machine -->
            <Frame IsVisible="{Binding ShowRegisterForm}" Style="{StaticResource Card}" VerticalOptions="Center" Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="🆕 Nouvelle Machine" Style="{StaticResource HeadingLabel}" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding ScannedEpc, StringFormat='Tag EPC : {0}'}" 
                           Style="{StaticResource CaptionLabel}" HorizontalTextAlignment="Center" />
                    
                    <BoxView Style="{StaticResource Divider}" />

                    <!-- Nom de la machine -->
                    <Label Text="Nom de la machine" Style="{StaticResource CaptionLabel}" />
                    <Frame Style="{StaticResource CardAlt}" Padding="0" HeightRequest="50">
                        <Entry Placeholder="Ex: Sertisseuse Auto K1" 
                               Text="{Binding NewMachineName}" 
                               Style="{StaticResource ModernEntry}" Margin="10,0" />
                    </Frame>

                    <!-- Département -->
                    <Label Text="Département" Style="{StaticResource CaptionLabel}" />
                    <Picker ItemsSource="{Binding DepartmentOptions}" 
                            SelectedItem="{Binding SelectedDepartment}" />

                    <!-- Boutons -->
                    <Button Text="✅ ENREGISTRER LA MACHINE"
                            Command="{Binding RegisterMachineCommand}"
                            BackgroundColor="#27AE60" TextColor="White"
                            HeightRequest="50" CornerRadius="10" FontAttributes="Bold" />
                    <Button Text="Annuler" 
                            Style="{StaticResource SecondaryButton}" 
                            Command="{Binding StartScanCommand}" 
                            HeightRequest="40" />
                </VerticalStackLayout>
            </Frame>

        </Grid>

        <!-- ═══ ZONE BASSE : Boutons Conditionnels selon le Rôle ═══ -->

        <!-- 🎓 TECHNICIEN : Bouton "Signaler Panne" (visible si machine = Running) -->
        <Button Grid.Row="2" 
                Text="🔴 SIGNALER PANNE"
                IsVisible="{Binding CanReportBroken}"
                Command="{Binding ReportBrokenCommand}"
                BackgroundColor="#E74C3C" TextColor="White"
                HeightRequest="60" CornerRadius="10" FontAttributes="Bold" />

        <!-- 🎓 AGENT MAINTENANCE : Bouton "Commencer Maintenance" (visible si machine = Broken) -->
        <Button Grid.Row="2" 
                Text="🔧 COMMENCER MAINTENANCE"
                IsVisible="{Binding CanStartMaintenance}"
                Command="{Binding StartMaintenanceCommand}"
                BackgroundColor="#F39C12" TextColor="White"
                HeightRequest="60" CornerRadius="10" FontAttributes="Bold" />

        <!-- 🎓 AGENT MAINTENANCE : Timer + Bouton "Maintenance Terminée" (visible si machine = InMaintenance) -->
        <VerticalStackLayout Grid.Row="2" IsVisible="{Binding CanEndMaintenance}" Spacing="10">
            <!-- Timer en temps réel -->
            <Frame BackgroundColor="#2C3E50" Padding="15" CornerRadius="10" HasShadow="False">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                    <Label Text="⏱️" FontSize="28" VerticalOptions="Center" />
                    <Label Text="{Binding MaintenanceTimer}" 
                           FontSize="32" FontFamily="RobotoBold" TextColor="#F39C12"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Frame>
            <!-- Bouton Terminer -->
            <Button Text="✅ MAINTENANCE TERMINÉE"
                    Command="{Binding EndMaintenanceCommand}"
                    BackgroundColor="#27AE60" TextColor="White"
                    HeightRequest="60" CornerRadius="10" FontAttributes="Bold" />
        </VerticalStackLayout>

        <!-- Start/Stop Floating Button if not scanning and no machine -->
        <Button Grid.Row="2" Text="DÉMARRER SCAN RFID" 
                IsVisible="{Binding IsScanning, Converter={StaticResource InverseBool}}"
                Command="{Binding StartScanCommand}"
                Style="{StaticResource PrimaryButton}" 
                VerticalOptions="End" />

        <Button Grid.Row="2" Text="ARRÊTER SCAN" 
                IsVisible="{Binding IsScanning}"
                Command="{Binding StopScanCommand}"
                BackgroundColor="#C0392B"
                Style="{StaticResource PrimaryButton}" 
                VerticalOptions="End" />

    </Grid>
</ContentPage>
