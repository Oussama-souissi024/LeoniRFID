<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LeoniRFID.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:LeoniRFID.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="LEONI RFID">

    <!-- 🎓 Pédagogie PFE : AppShell (Le chef d'orchestre de la navigation)
         La balise <Shell> définit la structure globale de l'application. 
         Les <FlyoutItem> sont les onglets du menu latéral (Flyout).
         L'attribut 'Route' ("dashboard", "scan"...) est indispensable pour naviguer
         via le code C# : Shell.Current.GoToAsync("//dashboard").
    -->

    <!-- ── Login (No Flyout) ─────────────────────────────────────────── -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="login"
        FlyoutItemIsVisible="False"
        Shell.FlyoutBehavior="Disabled" />

    <!-- ── Main App ──────────────────────────────────────────────────── -->
    <FlyoutItem Title="Dashboard" Icon="dashboard_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:DashboardPage}" 
            Route="dashboard" />
    </FlyoutItem>

    <FlyoutItem Title="RFID Scanner" Icon="scan_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:ScanPage}" 
            Route="scan" />
    </FlyoutItem>

    <FlyoutItem Title="Machine List" Icon="admin_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:MachineListPage}" 
            Route="machinelist" />
    </FlyoutItem>

    <FlyoutItem Title="Reports" Icon="report_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:ReportPage}" 
            Route="report" />
    </FlyoutItem>

    <!-- Maintenance Only (Managed in code-behind) -->
    <FlyoutItem x:Name="MaintenanceFlyoutItem" Title="🔧 Maintenance" Icon="scan_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:MaintenancePage}" 
            Route="maintenance" />
    </FlyoutItem>

    <!-- Admin Only (Managed in code-behind) -->
    <FlyoutItem x:Name="AdminFlyoutItem" Title="Administration" Icon="admin_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:AdminPage}" 
            Route="admin" />
    </FlyoutItem>

    <FlyoutItem x:Name="UserMgmtFlyoutItem" Title="User Management" Icon="admin_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:UserManagementPage}" 
            Route="usermanagement" />
    </FlyoutItem>

    <FlyoutItem x:Name="DepartmentFlyoutItem" Title="🏭 Departments" Icon="admin_icon.png">
        <ShellContent 
            ContentTemplate="{DataTemplate views:DepartmentPage}" 
            Route="departments" />
    </FlyoutItem>

    <MenuItem Text="Logout" Clicked="OnLogoutClicked" />

</Shell>
