<?xml version="1.0" encoding="utf-8" ?>
<!-- 🎓 Pédagogie PFE : Le DataBinding Fortement Typé
     Déclarer x:DataType permet à Visual Studio de vérifier pendant la compilation 
     que les liaisons de données (Bindings) existent bien dans LoginViewModel. -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             x:Class="LeoniRFID.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             x:DataType="vm:LoginViewModel">
             
    <!-- 🎓 Pédagogie PFE : Le DataBinding Fortement Typé
         Déclarer x:DataType permet à Visual Studio de vérifier pendant la compilation 
         que les liaisons de données (Bindings) existent bien dans LoginViewModel. -->

    <Grid RowDefinitions="*,Auto" Padding="30">
        
        <!-- Background Gradient (simplified with background color) -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#00205B" Offset="0.1" />
                <GradientStop Color="#001233" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Grid.Row="0" Spacing="25" VerticalOptions="Center">
            
            <!-- Logo Holder (PNG expected later) -->
            <Frame BackgroundColor="White" 
                   Padding="15" 
                   CornerRadius="10" 
                   WidthRequest="180" 
                   HorizontalOptions="Center"
                   HasShadow="False">
                <Label Text="LEONI" 
                       TextColor="#00205B" 
                       FontFamily="RobotoBold" 
                       FontSize="32" 
                       HorizontalTextAlignment="Center" 
                       VerticalTextAlignment="Center" />
            </Frame>

            <VerticalStackLayout Spacing="5" Margin="0,10,0,20">
                <Label Text="Production RFID" 
                       Style="{StaticResource HeadingLabel}" 
                       HorizontalTextAlignment="Center" />
                <Label Text="Suivi et Traçabilité Industrielle" 
                       Style="{StaticResource SubHeadingLabel}" 
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Login Form -->
            <VerticalStackLayout Spacing="15">
                
                <Frame Style="{StaticResource CardAlt}" Padding="0">
                    <Entry Placeholder="Email professionnel"
                           Keyboard="Email"
                           Text="{Binding Email}"
                           Style="{StaticResource ModernEntry}"
                           Margin="15,0" />
                </Frame>

                <!-- 🎓 Pédagogie PFE : Les Convertisseurs (Converters)
                     L'interface graphique ne sait pas faire de "NON Logique" (!IsFirstLogin).
                     On utilise donc un Convertisseur (InverseBool) qui transforme True en False 
                     (et inversement) pour cacher ce bloc quand on est en mode "Première connexion". -->
                <!-- ══ Champs Mot de passe classique (caché si première connexion) ══ -->
                <Frame Style="{StaticResource CardAlt}" Padding="0"
                       IsVisible="{Binding IsFirstLogin, Converter={StaticResource InverseBool}}">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Placeholder="Mot de passe"
                               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBool}}"
                               Text="{Binding Password}"
                               Style="{StaticResource ModernEntry}"
                               Margin="15,0" />
                        <ImageButton Grid.Column="1"
                                     Source="{Binding PasswordToggleIcon}"
                                     Command="{Binding TogglePasswordVisibilityCommand}"
                                     WidthRequest="44"
                                     HeightRequest="44"
                                     Margin="0,0,10,0"
                                     BackgroundColor="Transparent" />
                    </Grid>
                </Frame>

                <!-- ══ Bouton SE CONNECTER (caché si première connexion) ══ -->
                <Button Text="SE CONNECTER"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,0"
                        IsVisible="{Binding IsFirstLogin, Converter={StaticResource InverseBool}}" />

                <!-- ══ Première Connexion ══ -->
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,5">
                    <CheckBox IsChecked="{Binding IsFirstLogin}" 
                              Color="{StaticResource LeoniOrange}"
                              IsEnabled="{Binding CanUseFirstLogin}" />
                    <Label Text="C'est ma première connexion" 
                           TextColor="{Binding FirstLoginTextColor}" 
                           FontSize="14"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- ══ Message sous la case ══ -->
                <Label Text="{Binding FirstLoginHint}"
                       TextColor="{StaticResource LeoniOrange}"
                       FontSize="12" HorizontalTextAlignment="Center"
                       IsVisible="{Binding FirstLoginHint, Converter={StaticResource NotNullToVisible}}" />

                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsFirstLogin}">
                    <Frame Style="{StaticResource CardAlt}" Padding="0">
                        <Entry Placeholder="Nouveau mot de passe"
                               IsPassword="True"
                               Text="{Binding NewPassword}"
                               Style="{StaticResource ModernEntry}"
                               Margin="15,0" />
                    </Frame>
                    <Frame Style="{StaticResource CardAlt}" Padding="0">
                        <Entry Placeholder="Confirmer le mot de passe"
                               IsPassword="True"
                               Text="{Binding ConfirmPassword}"
                               Style="{StaticResource ModernEntry}"
                               Margin="15,0" />
                    </Frame>
                    <Button Text="DÉFINIR MON MOT DE PASSE"
                            Command="{Binding SetFirstPasswordCommand}"
                            Style="{StaticResource PrimaryButton}"
                            BackgroundColor="{StaticResource StatusInstalled}" />
                </VerticalStackLayout>
                

            </VerticalStackLayout>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#E74C3C"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNullToVisible}}" />

        </VerticalStackLayout>

        <!-- Footer -->
        <VerticalStackLayout Grid.Row="1" Spacing="2">
            <Label Text="© 2026 LEONI Wiring Systems" 
                   Style="{StaticResource CaptionLabel}" 
                   HorizontalTextAlignment="Center" />
            <Label Text="v1.0.0 Stable Build" 
                   Style="{StaticResource CaptionLabel}" 
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Overlay Loading -->
        <Grid Grid.RowSpan="2" 
              BackgroundColor="#AA000000" 
              IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>
