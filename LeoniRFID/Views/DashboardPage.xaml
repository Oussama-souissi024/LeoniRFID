<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Logout" Command="{Binding LogoutCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="24,30" Spacing="24">

            <!-- ═══ Hero / Welcome ═══ -->
            <VerticalStackLayout Spacing="5" Margin="0,0,0,5">
                <Label Text="We are LEONI." Style="{StaticResource HeadingLabel}" FontSize="28" TextColor="{StaticResource LeoniDarkBlue}" />
                <Label Text="Your Empowering Connection." Style="{StaticResource SubHeadingLabel}" TextColor="{StaticResource LeoniOrange}" FontAttributes="Italic" />
            </VerticalStackLayout>

            <!-- ═══ Profil utilisateur ═══ -->
            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                <Border WidthRequest="60" HeightRequest="60" 
                        StrokeShape="RoundRectangle 30" StrokeThickness="0"
                        Padding="0" Background="{StaticResource PrimaryGradient}">
                    <Label Text="{Binding UserInitials}" TextColor="White"
                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                           FontFamily="RobotoBold" FontSize="24" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding UserName}" Style="{StaticResource HeadingLabel}" FontSize="18" />
                    <Label Text="{Binding UserRole}" Style="{StaticResource SubHeadingLabel}" />
                </VerticalStackLayout>
            </Grid>

            <!-- ═══ Quick Actions ═══ -->
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="12" RowSpacing="12">

                <!-- Scanner RFID (Full Width) -->
                <Border Grid.ColumnSpan="2" Style="{StaticResource InteractiveBorderCard}" Background="{StaticResource BlueGradient}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToScanCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                             <Label Text="Start a Scan" Style="{StaticResource HeadingLabel}" TextColor="White" FontSize="22" />
                             <Label Text="Scan a Zebra UHF RFID tag" Style="{StaticResource BodyLabel}" TextColor="#E2E8F0" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="📡" FontSize="40" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Maintenance (Full Width, visible Maintenance + Admin) -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource InteractiveBorderCard}" 
                        Background="{StaticResource PrimaryGradient}" IsVisible="{Binding IsMaintenance}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToMaintenanceCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                             <Label Text="🔧 Maintenance" Style="{StaticResource HeadingLabel}" TextColor="White" FontSize="22" />
                             <Label Text="Manage ongoing interventions" Style="{StaticResource BodyLabel}" TextColor="#FFF3E0" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="🔧" FontSize="40" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Machines -->
                <Border Grid.Row="2" Style="{StaticResource InteractiveBorderCard}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToMachinesCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Padding="10">
                        <Label Text="🏭" FontSize="36" HorizontalTextAlignment="Center" />
                        <Label Text="Machines" Style="{StaticResource HeadingLabel}" FontSize="15" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Rapports -->
                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource InteractiveBorderCard}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToReportCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Padding="10">
                        <Label Text="📊" FontSize="36" HorizontalTextAlignment="Center" />
                        <Label Text="Reports" Style="{StaticResource HeadingLabel}" FontSize="15" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- ═══ Admin Quick Access (visible Admin only) ═══ -->
            <Border Style="{StaticResource InteractiveBorderCard}" IsVisible="{Binding IsAdmin}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToAdminCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" Padding="5">
                    <Label Text="⚙️" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Administration" Style="{StaticResource HeadingLabel}" FontSize="16" />
                        <Label Text="Users, departments, settings" 
                               FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- ═══ Statistiques Production ═══ -->
            <Label Text="Production Statistics" Style="{StaticResource HeadingLabel}" FontSize="18" />
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10" RowDefinitions="Auto, Auto" RowSpacing="10">
                <Border Style="{StaticResource BorderCardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding ActiveCount}" TextColor="#27AE60" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="✅ Active" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource BorderCardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding DefectCount}" TextColor="#E74C3C" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="🔴 Defect" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource BorderCardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding InMaintenanceCount}" TextColor="#F39C12" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="🔧 Maint." FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource BorderCardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding PassiveCount}" TextColor="#3498DB" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="⏸️ Passive" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource BorderCardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding ScrappedCount}" TextColor="#95A5A6" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="❌ Scrapped" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource BorderCardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding TotalMachines}" TextColor="{StaticResource TextPrimary}" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="📊 Total" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ═══ Activités Récentes ═══ -->
            <Label Text="Recent Activities" Style="{StaticResource HeadingLabel}" FontSize="16" />
            <CollectionView ItemsSource="{Binding RecentEvents}" HeightRequest="300">
                <CollectionView.EmptyView>
                    <Label Text="No recent activity." HorizontalTextAlignment="Center" Margin="20" TextColor="{StaticResource TextMuted}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ScanEvent">
                        <Border Style="{StaticResource BorderCardAlt}" Margin="0,5" Padding="12">
                             <Grid ColumnDefinitions="Auto, *, Auto">
                                 <Label Text="{Binding EventIcon}" FontSize="24" VerticalOptions="Center" />
                                 <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                     <Label Text="{Binding TagId}" FontFamily="RobotoBold" FontSize="13" MaxLines="1" LineBreakMode="TailTruncation" />
                                     <Label Text="{Binding EventType}" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                 </VerticalStackLayout>
                                 <Label Grid.Column="2" Text="{Binding TimestampDisplay}" FontSize="10" TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                             </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
