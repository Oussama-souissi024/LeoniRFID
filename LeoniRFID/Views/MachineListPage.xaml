<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.MachineListPage"
             x:DataType="vm:MachineListViewModel"
             Title="Machine List">

    <Grid RowDefinitions="Auto, *">

        <!-- ═══ Filtres ═══ -->
        <Border Grid.Row="0" Style="{StaticResource BorderCard}" Margin="10" Padding="15">
            <VerticalStackLayout Spacing="10">

                <!-- Recherche par nom -->
                <Border Style="{StaticResource BorderCardAlt}" Padding="0" HeightRequest="46">
                    <Entry Placeholder="🔍 Search by name, tag, serial no..."
                           Text="{Binding SearchText}"
                           Style="{StaticResource ModernEntry}"
                           Margin="15,0" />
                </Border>

                <!-- Statut + Département côte à côte -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="3">
                        <Label Text="Status" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                        <Picker ItemsSource="{Binding StatusOptions}" 
                                SelectedItem="{Binding SelectedStatus}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                        <Label Text="Department" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                        <Picker ItemsSource="{Binding DepartmentOptions}" 
                                SelectedItem="{Binding SelectedDepartment}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Boutons -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                    <Button Text="🔍 Filter" 
                            Command="{Binding ApplyFiltersCommand}"
                            Style="{StaticResource PrimaryButton}" 
                            HeightRequest="42" />
                    <Button Grid.Column="1" Text="✖ Reset"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HeightRequest="42" Padding="15,0" />
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- ═══ Liste des machines ═══ -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Machines}" Margin="10,0"
                        SelectionMode="Single"
                        SelectionChanged="OnMachineSelected">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" Spacing="10" Padding="40">
                    <Label Text="📦" FontSize="48" HorizontalTextAlignment="Center" />
                    <Label Text="No machines found" 
                           Style="{StaticResource HeadingLabel}" 
                           HorizontalTextAlignment="Center" FontSize="16" />
                    <Label Text="Try modifying your filters."
                           TextColor="{StaticResource TextMuted}" 
                           HorizontalTextAlignment="Center" FontSize="12" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Machine">
                    <Border Style="{StaticResource InteractiveBorderCard}" Margin="0,5" Padding="15">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="3">
                            <!-- Nom -->
                            <Label Text="{Binding StandardEquipmentName}" FontFamily="RobotoBold" FontSize="15" />
                            <!-- Statut badge -->
                            <Label Grid.Column="1" Text="{Binding StatusDisplay}" 
                                   FontSize="12" FontFamily="RobotoBold" VerticalOptions="Center" />
                            <!-- Plant -->
                            <Label Grid.Row="1" Text="{Binding Plant}" 
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                            <!-- Tag Reference -->
                            <Label Grid.Row="2" Grid.ColumnSpan="2" 
                                   Text="{Binding TagReference, StringFormat='🏷️ EPC: {0}'}" 
                                   FontSize="10" TextColor="{StaticResource TextMuted}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading -->
        <Grid Grid.RowSpan="2" BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="True" VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
