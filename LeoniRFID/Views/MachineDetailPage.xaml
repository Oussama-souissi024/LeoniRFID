<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.MachineDetailPage"
             x:DataType="vm:MachineDetailViewModel"
             x:Name="detailPage"
             Title="Machine Details">

    <Grid RowDefinitions="*">
        
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- ═══ Header Card ═══ -->
                <Border Style="{StaticResource BorderCard}" Padding="20">
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="12">
                        
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding Machine.StandardEquipmentName}" Style="{StaticResource HeadingLabel}" />
                                <Label Text="{Binding Machine.TagReference, StringFormat='🏷️ EPC: {0}'}" Style="{StaticResource CaptionLabel}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 8" Padding="12,6" StrokeThickness="0"
                                    BackgroundColor="{Binding Machine.EquipmentStatus, Converter={StaticResource StatusToBadge}}"
                                    VerticalOptions="Start">
                                <Label Text="{Binding Machine.StatusDisplay}" TextColor="{Binding Machine.EquipmentStatus, Converter={StaticResource StatusToColor}}" 
                                       FontFamily="RobotoBold" FontSize="12" />
                            </Border>
                        </Grid>

                        <BoxView Grid.Row="1" Style="{StaticResource Divider}" />

                        <!-- Infos détaillées -->
                        <Grid Grid.Row="2" ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" RowSpacing="10" ColumnSpacing="10">
                            <VerticalStackLayout>
                                <Label Text="Plant" Style="{StaticResource CaptionLabel}" />
                                <Label Text="{Binding Machine.Plant}" Style="{StaticResource BodyLabel}" FontFamily="RobotoBold" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Area" Style="{StaticResource CaptionLabel}" />
                                <Label Text="{Binding Machine.Area}" Style="{StaticResource BodyLabel}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1">
                                <Label Text="Serial No" Style="{StaticResource CaptionLabel}" />
                                <Label Text="{Binding Machine.SerialNumber}" Style="{StaticResource BodyLabel}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <Label Text="Last Update" Style="{StaticResource CaptionLabel}" />
                                <Label Text="{Binding Machine.LastUpdatedDisplay}" Style="{StaticResource BodyLabel}" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Notes -->
                        <VerticalStackLayout Grid.Row="3" IsVisible="{Binding Machine.Notes, Converter={StaticResource NotNullToVisible}}">
                            <Label Text="Notes" Style="{StaticResource CaptionLabel}" />
                            <Label Text="{Binding Machine.Notes}" Style="{StaticResource BodyLabel}" 
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                        
                    </Grid>
                </Border>

                <!-- ═══ CHANGEMENT DE STATUT (Admin + Technician) ═══ -->
                <Border Style="{StaticResource BorderCard}" Padding="20"
                        IsVisible="{Binding CanChangeStatus}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="⚡ Change status" Style="{StaticResource HeadingLabel}" FontSize="18" />
                        <Label Text="Tap the desired new status:" 
                               FontSize="12" TextColor="{StaticResource TextSecondary}" />

                        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                            <!-- En marche (Active) -->
                            <Button Text="✅ Active"
                                    Command="{Binding ChangeStatusCommand}"
                                    CommandParameter="Active"
                                    BackgroundColor="#27AE60"
                                    TextColor="White"
                                    FontFamily="RobotoBold" FontSize="12"
                                    HeightRequest="50" CornerRadius="12" />

                            <!-- En pause (Passive) -->
                            <Button Grid.Column="1" 
                                    Text="⏸️ Passive"
                                    Command="{Binding ChangeStatusCommand}"
                                    CommandParameter="Passive"
                                    BackgroundColor="#3498DB"
                                    TextColor="White"
                                    FontFamily="RobotoBold" FontSize="12"
                                    HeightRequest="50" CornerRadius="12" />

                            <!-- En panne (Defect) -->
                            <Button Grid.Column="2" 
                                    Text="🔴 Defect"
                                    Command="{Binding ChangeStatusCommand}"
                                    CommandParameter="Defect"
                                    BackgroundColor="#E74C3C"
                                    TextColor="White"
                                    FontFamily="RobotoBold" FontSize="12"
                                    HeightRequest="50" CornerRadius="12" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ Admin Actions ═══ -->
                <Border IsVisible="{Binding IsAdmin}" Style="{StaticResource BorderCardAlt}" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="👑 Administrator Actions" Style="{StaticResource SubHeadingLabel}" />
                        <Button Text="✏️ Edit information" 
                                Command="{Binding StartEditCommand}" 
                                Style="{StaticResource SecondaryButton}" />
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ Historique des scans ═══ -->
                <Label Text="📋 Scan History" Style="{StaticResource HeadingLabel}" FontSize="16" />
                <CollectionView ItemsSource="{Binding Events}" MinimumHeightRequest="200">
                    <CollectionView.EmptyView>
                        <Label Text="No registered events." 
                               TextColor="{StaticResource TextMuted}" HorizontalTextAlignment="Center" Margin="20" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ScanEvent">
                            <Border Style="{StaticResource BorderCardAlt}" Padding="10" Margin="0,2">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Text="{Binding EventIcon}" FontSize="20" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                        <Label Text="{Binding EventType}" FontFamily="RobotoBold" FontSize="13" />
                                        <Label Text="{Binding Notes}" TextColor="{StaticResource TextSecondary}" FontSize="11" 
                                               IsVisible="{Binding Notes, Converter={StaticResource NotNullToVisible}}" 
                                               MaxLines="2" LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding TimestampDisplay}" FontSize="10" 
                                           TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading Overlay -->
        <Grid BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>
