<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.MaintenancePage"
             x:DataType="vm:MaintenanceViewModel"
             x:Name="maintenancePage"
             Title="🔧 Maintenance">

    <Grid RowDefinitions="*">

        <!-- ═══ VUE LISTE : Machines en panne + en maintenance ═══ -->
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Titre + compteurs -->
                <Border Style="{StaticResource BorderCard}" Padding="20">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🔧 Maintenance Dashboard" Style="{StaticResource HeadingLabel}" FontSize="20" />
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Border Style="{StaticResource BorderCardAlt}" Padding="12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="{Binding BrokenCount}" TextColor="#E74C3C" FontSize="28" 
                                           FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                                    <Label Text="🔴 Defect" FontSize="11" HorizontalTextAlignment="Center" 
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource BorderCardAlt}" Padding="12">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="{Binding InMaintenanceCount}" TextColor="#F39C12" FontSize="28" 
                                           FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                                    <Label Text="🔧 In Progress" FontSize="11" HorizontalTextAlignment="Center" 
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Section : Machines en maintenance (prioritaire) -->
                <CollectionView ItemsSource="{Binding InMaintenanceMachines}"
                                SelectionMode="Single"
                                SelectionChanged="OnMachineSelected">
                    <CollectionView.Header>
                        <Label Text="⏱️ Maintenance in progress" Style="{StaticResource HeadingLabel}" FontSize="16" Margin="0,0,0,5" />
                    </CollectionView.Header>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Machine">
                            <Border Style="{StaticResource InteractiveBorderCard}" Margin="0,4" Padding="15"
                                    Stroke="#F39C12" StrokeThickness="1.5">
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">
                                    <Label Text="{Binding StandardEquipmentName}" FontFamily="RobotoBold" FontSize="15" />
                                    <Label Grid.Column="1" Text="🔧 In progress ▶" TextColor="#F39C12" 
                                           FontFamily="RobotoBold" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="15">
                                        <Label Text="{Binding Plant}" FontSize="12" 
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding TagReference, StringFormat='🏷️ {0}'}" FontSize="12" 
                                               TextColor="{StaticResource TextMuted}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Section : Machines en panne (à traiter) -->
                <CollectionView ItemsSource="{Binding BrokenMachines}"
                                SelectionMode="Single"
                                SelectionChanged="OnMachineSelected">
                    <CollectionView.Header>
                        <Label Text="🔴 Defective Machines — To handle" Style="{StaticResource HeadingLabel}" FontSize="16" Margin="0,5,0,5" />
                    </CollectionView.Header>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="30" Spacing="10">
                            <Label Text="🎉" FontSize="48" HorizontalTextAlignment="Center" />
                            <Label Text="No defective machines!" 
                                   Style="{StaticResource SubHeadingLabel}" 
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Machine">
                            <Border Style="{StaticResource InteractiveBorderCard}" Margin="0,4" Padding="15"
                                    Stroke="#E74C3C" StrokeThickness="1.5">
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">
                                    <Label Text="{Binding StandardEquipmentName}" FontFamily="RobotoBold" FontSize="15" />
                                    <Label Grid.Column="1" Text="🔴 Defect ▶" TextColor="#E74C3C" 
                                           FontFamily="RobotoBold" FontSize="12" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="15">
                                        <Label Text="{Binding Plant}" FontSize="12" 
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding TagReference, StringFormat='🏷️ {0}'}" FontSize="12" 
                                               TextColor="{StaticResource TextMuted}" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Section : Historique des interventions terminées -->
                <CollectionView ItemsSource="{Binding RecentSessions}">
                    <CollectionView.Header>
                        <Label Text="📋 Recent History" Style="{StaticResource HeadingLabel}" FontSize="16" Margin="0,10,0,5" />
                    </CollectionView.Header>
                    <CollectionView.EmptyView>
                        <Label Text="No completed interventions." 
                               TextColor="{StaticResource TextMuted}" HorizontalTextAlignment="Center" Margin="20" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MaintenanceSession">
                            <Border Style="{StaticResource BorderCardAlt}" Margin="0,3" Padding="12" StrokeShape="RoundRectangle 10">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                    <Label Text="✅" FontSize="22" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding DurationDisplay}" FontFamily="RobotoBold" FontSize="14" />
                                        <Label Text="{Binding StartedAtDisplay, StringFormat='Start: {0}'}" 
                                               FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding Notes}" FontSize="11" 
                                               TextColor="{StaticResource TextMuted}" MaxLines="2" 
                                               LineBreakMode="TailTruncation"
                                               IsVisible="{Binding Notes, Converter={StaticResource NotNullToVisible}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading overlay -->
        <Grid BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="True" VerticalOptions="Center" Color="White" />
        </Grid>

    </Grid>
</ContentPage>
