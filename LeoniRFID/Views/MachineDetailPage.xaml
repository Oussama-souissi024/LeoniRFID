<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.MachineDetailPage"
             x:DataType="vm:MachineDetailViewModel"
             Title="Détails Machine">

    <!-- 🎓 Pédagogie PFE : ScrollView
         ScrollView permet de faire défiler le contenu verticalement (scroll) 
         si l'écran du téléphone est trop petit pour tout afficher. -->
    <Grid RowDefinitions="*, Auto">
        
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- Header Card -->
                <Frame Style="{StaticResource Card}" Padding="20" CornerRadius="15">
                    <Grid RowDefinitions="Auto, Auto, Auto" RowSpacing="15">
                        
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding Machine.Name}" Style="{StaticResource HeadingLabel}" />
                                <Label Text="{Binding Machine.TagId, StringFormat='EPC : {0}'}" Style="{StaticResource CaptionLabel}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 8" Padding="12,6"
                                    BackgroundColor="{Binding Machine.Status, Converter={StaticResource StatusToBadge}}"
                                    VerticalOptions="Start">
                                <Label Text="{Binding Machine.Status}" TextColor="{Binding Machine.Status, Converter={StaticResource StatusToColor}}" 
                                       FontFamily="RobotoBold" FontSize="12" />
                            </Border>
                        </Grid>

                        <BoxView Grid.Row="1" Style="{StaticResource Divider}" />

                        <Grid Grid.Row="2" ColumnDefinitions="*, *">
                            <VerticalStackLayout>
                                <Label Text="Département" Style="{StaticResource CaptionLabel}" />
                                <Label Text="{Binding Machine.Department}" Style="{StaticResource BodyLabel}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="Dernière Maj" Style="{StaticResource CaptionLabel}" />
                                <Label Text="{Binding Machine.LastUpdatedDisplay}" Style="{StaticResource BodyLabel}" />
                            </VerticalStackLayout>
                        </Grid>
                        
                    </Grid>
                </Frame>

                <!-- Admin Actions -->
                <Frame IsVisible="{Binding IsAdmin}" Style="{StaticResource CardAlt}" Padding="15" CornerRadius="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Actions Administrateur" Style="{StaticResource SubHeadingLabel}" />
                        
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Button Text="Éditer" 
                                    Command="{Binding EditMachineCommand}" 
                                    Style="{StaticResource SecondaryButton}" />
                            <Button Grid.Column="1" 
                                    Text="Scanner" 
                                    Command="{Binding RecordMaintenanceCommand}" 
                                    Style="{StaticResource PrimaryButton}" />
                        </Grid>
                        <Button Text="Supprimer Machine" 
                                Command="{Binding DeleteMachineCommand}" 
                                Style="{StaticResource DangerButton}" Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- History -->
                <Label Text="Historique des scans" Style="{StaticResource HeadingLabel}" FontSize="16" />
                <CollectionView ItemsSource="{Binding Events}" MinimumHeightRequest="200">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ScanEvent">
                            <Frame Style="{StaticResource CardAlt}" Padding="10" Margin="0,2" CornerRadius="10">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Text="{Binding EventIcon}" FontSize="20" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                        <Label Text="{Binding EventType}" FontFamily="RobotoBold" FontSize="13" />
                                        <Label Text="{Binding Notes}" TextColor="{StaticResource TextSecondary}" FontSize="11" IsVisible="{Binding Notes, Converter={StaticResource NotNullToVisible}}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding TimestampDisplay}" FontSize="10" TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" />
        </Grid>

    </Grid>
</ContentPage>
