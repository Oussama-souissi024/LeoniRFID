<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.AdminPage"
             x:DataType="vm:AdminViewModel"
             x:Name="adminPage"
             Title="Administration Pro">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Header Actions -->
        <Frame Grid.Row="0" BackgroundColor="{StaticResource LeoniMidBlue}" Margin="10" Padding="15" CornerRadius="10">
            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Button Text="IMPORTER EXCEL" Command="{Binding ImportExcelCommand}" Style="{StaticResource PrimaryButton}" HeightRequest="44" Padding="20,0" />
                <Button Text="MODÈLE EXCEL" Command="{Binding GenerateSampleExcelCommand}" Style="{StaticResource SecondaryButton}" HeightRequest="44" Padding="20,0" />
            </HorizontalStackLayout>
        </Frame>

        <!-- Machine List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Machines}" Margin="10,0">
            <CollectionView.Header>
                <Label Text="Inventaire des Machines" Style="{StaticResource HeadingLabel}" Margin="5,10" FontSize="16" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Machine">
                    <Frame Style="{StaticResource CardAlt}" Margin="0,5" Padding="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Name}" FontFamily="RobotoBold" FontSize="15" />
                                <Label Text="{Binding TagId}" Style="{StaticResource CaptionLabel}" />
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Department}" FontSize="11" TextColor="{StaticResource LeoniOrange}" />
                                    <Label Text="•" TextColor="{StaticResource TextMuted}" />
                                    <Label Text="{Binding Status}" FontSize="11" TextColor="{Binding Status, Converter={StaticResource StatusToColor}}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <ImageButton Source="edit_icon.png" Command="{Binding BindingContext.EditMachineCommand, Source={x:Reference adminPage}}" CommandParameter="{Binding .}" WidthRequest="32" HeightRequest="32" x:DataType="{x:Null}" />
                                <ImageButton Source="delete_icon.png" Command="{Binding BindingContext.DeleteMachineCommand, Source={x:Reference adminPage}}" CommandParameter="{Binding .}" WidthRequest="32" HeightRequest="32" x:DataType="{x:Null}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" BackgroundColor="#AA000000" IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="15">
                <ActivityIndicator IsRunning="True" Color="White" />
                <Label Text="{Binding ImportStatus}" TextColor="White" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
