<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.ReportPage"
             x:DataType="vm:ReportViewModel"
             Title="Rapports d'activité">

    <ScrollView>
        <VerticalStackLayout Padding="10" Spacing="15">

            <!-- ═══ FILTRES ═══ -->
            <Frame Style="{StaticResource Card}" Padding="15">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Filtres" Style="{StaticResource HeadingLabel}" FontSize="16" />
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Département" Style="{StaticResource CaptionLabel}" />
                            <Picker ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Statut" Style="{StaticResource CaptionLabel}" />
                            <Picker ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" />
                        </VerticalStackLayout>
                    </Grid>
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                        <VerticalStackLayout>
                            <Label Text="Date début" Style="{StaticResource CaptionLabel}" />
                            <DatePicker Date="{Binding StartDate}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout>
                            <Label Text="Date fin" Style="{StaticResource CaptionLabel}" />
                            <DatePicker Date="{Binding EndDate}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- ═══ BOUTONS D'ACTION ═══ -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                <Button Text="📊 RAPPORT MACHINES" 
                        Command="{Binding RunReportCommand}" 
                        Style="{StaticResource PrimaryButton}" HeightRequest="44" />
                <Button Grid.Column="1" Text="🔧 RAPPORT MAINTENANCE" 
                        Command="{Binding RunMaintenanceReportCommand}" 
                        BackgroundColor="#F39C12" TextColor="White"
                        HeightRequest="44" CornerRadius="10" FontAttributes="Bold" />
            </Grid>

            <Button Text="📥 EXPORTER EN EXCEL (.xlsx)" 
                    Command="{Binding ExportToExcelCommand}" 
                    Style="{StaticResource SecondaryButton}" HeightRequest="44" />

            <!-- ═══ RÉSULTATS MACHINES ═══ -->
            <CollectionView ItemsSource="{Binding FilteredMachines}">
                <CollectionView.EmptyView>
                    <Label Text="Utilisez les filtres pour afficher des données." 
                           HorizontalTextAlignment="Center" Margin="50" 
                           TextColor="{StaticResource TextMuted}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Machine">
                        <Frame Style="{StaticResource CardAlt}" Margin="0,5" Padding="12">
                             <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}" FontFamily="RobotoBold" FontSize="14" />
                                    <Label Text="{Binding Department}" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                    <Label Text="{Binding TagId}" FontSize="10" TextColor="{StaticResource TextMuted}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding StatusDisplay}" 
                                       FontSize="12" FontFamily="RobotoBold" VerticalOptions="Center" />
                             </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ═══ SECTION RAPPORT MAINTENANCE ═══ -->

            <!-- Statistiques Maintenance -->
            <Frame Style="{StaticResource Card}" Padding="15" 
                   IsVisible="{Binding TotalInterventions, Converter={StaticResource IntToBool}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📊 Statistiques Maintenance" Style="{StaticResource HeadingLabel}" FontSize="16" />
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <Frame Style="{StaticResource CardAlt}" Padding="10">
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="{Binding TotalInterventions}" FontSize="22" FontFamily="RobotoBold" 
                                       TextColor="#F39C12" HorizontalTextAlignment="Center" />
                                <Label Text="Interventions" FontSize="10" HorizontalTextAlignment="Center" 
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="1" Style="{StaticResource CardAlt}" Padding="10">
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="{Binding AverageDuration}" FontSize="16" FontFamily="RobotoBold" 
                                       TextColor="#3498DB" HorizontalTextAlignment="Center" />
                                <Label Text="Durée Moy." FontSize="10" HorizontalTextAlignment="Center" 
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Frame>
                        <Frame Grid.Column="2" Style="{StaticResource CardAlt}" Padding="10">
                            <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                                <Label Text="{Binding TotalDuration}" FontSize="16" FontFamily="RobotoBold" 
                                       TextColor="#E74C3C" HorizontalTextAlignment="Center" />
                                <Label Text="Durée Tot." FontSize="10" HorizontalTextAlignment="Center" 
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Liste des Interventions -->
            <CollectionView ItemsSource="{Binding MaintenanceSessions}">
                <CollectionView.EmptyView>
                    <Label Text="" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:MaintenanceSession">
                        <Frame Style="{StaticResource CardAlt}" Margin="0,5" Padding="12">
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="{Binding StartedAtDisplay, StringFormat='🔧 Début : {0}'}" 
                                           FontFamily="RobotoBold" FontSize="13" />
                                    <Label Grid.Column="1" Text="{Binding DurationDisplay}" 
                                           FontSize="13" FontFamily="RobotoBold" 
                                           TextColor="#F39C12" VerticalOptions="Center" />
                                </Grid>
                                <Label Text="{Binding EndedAtDisplay, StringFormat='✅ Fin : {0}'}" 
                                       FontSize="11" TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding MachineId, StringFormat='Machine ID : {0}'}" 
                                       FontSize="10" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
