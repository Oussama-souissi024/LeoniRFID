<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Tableau de bord">

    <!-- Commentaire pédagogique :
         - `ToolbarItems` permet d'ajouter des actions accessibles dans la barre d'app.
         - Les commandes sont liées au ViewModel via `Binding` pour séparer UI et logique.
    -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Déconnexion" Command="{Binding LogoutCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="24,30" Spacing="30">

            <!-- Hero / Welcome Section -->
            <VerticalStackLayout Spacing="5" Margin="0,0,0,10">
                <Label Text="We are LEONI." Style="{StaticResource HeadingLabel}" FontSize="28" TextColor="{StaticResource LeoniDarkBlue}" />
                <Label Text="Your Empowering Connection." Style="{StaticResource SubHeadingLabel}" TextColor="{StaticResource LeoniOrange}" FontAttributes="Italic" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                <Frame WidthRequest="60" 
                       HeightRequest="60" 
                       CornerRadius="30" 
                       Padding="0" 
                       BackgroundColor="{StaticResource LeoniOrange}"
                       HasShadow="False"
                       BorderColor="Transparent">
                    <Label Text="{Binding UserInitials}" 
                           TextColor="White"
                           HorizontalTextAlignment="Center" 
                           VerticalTextAlignment="Center"
                           FontFamily="RobotoBold" 
                           FontSize="24" />
                </Frame>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding UserName}" Style="{StaticResource HeadingLabel}" FontSize="18" />
                    <Label Text="{Binding UserRole}" Style="{StaticResource SubHeadingLabel}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Quick Action Cards -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" RowDefinitions="Auto, Auto" RowSpacing="15">
                <!-- Main Scan Card (Full Width) -->
                <Frame Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource Card}" CornerRadius="20" BackgroundColor="{StaticResource LeoniDarkBlue}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToScanAsyncCommand}" />
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                             <Label Text="Lancer un Scan" Style="{StaticResource HeadingLabel}" TextColor="White" FontSize="22" />
                             <Label Text="Scanner un tag UHF RFID Zebra" Style="{StaticResource BodyLabel}" TextColor="#E2E8F0" />
                        </VerticalStackLayout>
                        <!-- Example of replacing the missing icon with an emoji for now if image isn't great -->
                        <Label Grid.Column="1" Text="📡" FontSize="40" VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" Style="{StaticResource CardAlt}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToReportAsyncCommand}" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Padding="10">
                        <Label Text="📊" FontSize="36" HorizontalTextAlignment="Center" />
                        <Label Text="Rapports" Style="{StaticResource HeadingLabel}" FontSize="16" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource CardAlt}" IsVisible="{Binding IsAdmin}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAdminAsyncCommand}" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Padding="10">
                        <Label Text="⚙️" FontSize="36" HorizontalTextAlignment="Center" />
                        <Label Text="Admin" Style="{StaticResource HeadingLabel}" FontSize="16" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Stats Grid (Workflow Maintenance) -->
            <Label Text="Statistiques Production" Style="{StaticResource HeadingLabel}" FontSize="18" />
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10" RowDefinitions="Auto, Auto" RowSpacing="10">
                <Frame Style="{StaticResource CardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding RunningCount}" TextColor="#27AE60" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="✅ En Marche" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" Style="{StaticResource CardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding BrokenCount}" TextColor="#E74C3C" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="🔴 En Panne" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="2" Style="{StaticResource CardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding InMaintenanceCount}" TextColor="#F39C12" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="🔧 Maint." FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Style="{StaticResource CardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding PausedCount}" TextColor="#9B59B6" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="⏸️ En Pause" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Grid.Column="1" Style="{StaticResource CardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding RemovedCount}" TextColor="#95A5A6" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="❌ Retiré" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Grid.Column="2" Style="{StaticResource CardAlt}" Padding="10,15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding TotalMachines}" TextColor="{StaticResource TextPrimary}" FontSize="22" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="📊 Total" FontSize="10" HorizontalTextAlignment="Center" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Sync Section -->
            <Frame Style="{StaticResource CardAlt}" Padding="20">
                <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label Text="État Synchronisation" Style="{StaticResource HeadingLabel}" FontSize="15" />
                        <Label Text="{Binding SyncStatus}" TextColor="{StaticResource TextSecondary}" FontSize="13" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="Synchroniser" Command="{Binding SyncNowCommand}" 
                            Style="{StaticResource SecondaryButton}" HeightRequest="44" Padding="15,0" FontSize="13" />
                </Grid>
            </Frame>

            <!-- Recent Activity -->
            <Label Text="Activités Récentes" Style="{StaticResource HeadingLabel}" FontSize="16" />
            <CollectionView ItemsSource="{Binding RecentEvents}" HeightRequest="300">
                <CollectionView.EmptyView>
                    <Label Text="Aucune activité récente." HorizontalTextAlignment="Center" Margin="20" TextColor="{StaticResource TextMuted}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ScanEvent">
                        <Frame Style="{StaticResource CardAlt}" Margin="0,5" Padding="12" CornerRadius="10">
                             <Grid ColumnDefinitions="Auto, *, Auto">
                                 <Label Text="{Binding EventIcon}" FontSize="24" VerticalOptions="Center" />
                                 <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                     <Label Text="{Binding TagId}" FontFamily="RobotoBold" FontSize="13" MaxLines="1" LineBreakMode="TailTruncation" />
                                     <Label Text="{Binding EventType}" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                 </VerticalStackLayout>
                                 <Label Grid.Column="2" Text="{Binding TimestampDisplay}" FontSize="10" TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                             </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
