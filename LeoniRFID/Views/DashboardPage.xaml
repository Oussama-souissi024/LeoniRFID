<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:LeoniRFID.ViewModels"
             xmlns:models="clr-namespace:LeoniRFID.Models"
             x:Class="LeoniRFID.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Tableau de bord">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Déconnexion" Command="{Binding LogoutCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Welcome Section -->
            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                <Border StrokeShape="RoundRectangle 30,30,30,30" 
                        WidthRequest="60" 
                        HeightRequest="60" 
                        Padding="0" 
                        BackgroundColor="{StaticResource LeoniOrange}"
                        Stroke="Transparent">
                    <Label Text="{Binding UserInitials}" 
                           TextColor="White"
                           HorizontalTextAlignment="Center" 
                           VerticalTextAlignment="Center"
                           FontFamily="RobotoBold" 
                           FontSize="24" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding UserName}" Style="{StaticResource HeadingLabel}" FontSize="18" />
                    <Label Text="{Binding UserRole}" Style="{StaticResource SubHeadingLabel}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Quick Action Cards -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" RowDefinitions="Auto, Auto" RowSpacing="15">
                <Border Style="{StaticResource Card}" Padding="20" StrokeShape="RoundRectangle 15">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToScanAsyncCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Spacing="5">
                             <Label Text="Lancer un Scan" Style="{StaticResource HeadingLabel}" />
                             <Label Text="Scanner un tag UHF RFID Zebra" Style="{StaticResource SubHeadingLabel}" />
                        </VerticalStackLayout>
                        <Image Grid.Column="1" Source="scan_icon.png" WidthRequest="48" HeightRequest="48" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardAlt}" StrokeShape="RoundRectangle 15">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToReportAsyncCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📑" FontSize="32" HorizontalTextAlignment="Center" />
                        <Label Text="Rapports" Style="{StaticResource BodyLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardAlt}" IsVisible="{Binding IsAdmin}" StrokeShape="RoundRectangle 15">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAdminAsyncCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="⚙️" FontSize="32" HorizontalTextAlignment="Center" />
                        <Label Text="Admin" Style="{StaticResource BodyLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Stats Grid -->
            <Label Text="Statistiques Production" Style="{StaticResource HeadingLabel}" FontSize="16" />
            <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10" RowDefinitions="Auto, Auto" RowSpacing="10">
                <Border Style="{StaticResource CardAlt}" Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="{Binding TotalMachines}" TextColor="White" FontSize="20" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="Total" Style="{StaticResource CaptionLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border Style="{StaticResource CardAlt}" Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="{Binding InstalledCount}" TextColor="{StaticResource StatusInstalled}" FontSize="20" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="Installés" Style="{StaticResource CaptionLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border Style="{StaticResource CardAlt}" Padding="10" StrokeShape="RoundRectangle 10">
                    <VerticalStackLayout>
                        <Label Text="{Binding MaintenanceCount}" TextColor="{StaticResource StatusMaintenance}" FontSize="20" FontFamily="RobotoBold" HorizontalTextAlignment="Center" />
                        <Label Text="Maintenance" Style="{StaticResource CaptionLabel}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Sync Section -->
            <Border Style="{StaticResource CardAlt}" Padding="15" StrokeShape="RoundRectangle 10">
                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="État Synchronisation" Style="{StaticResource BodyLabel}" />
                        <Label Text="{Binding SyncStatus}" TextColor="{StaticResource TextSecondary}" FontSize="12" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="Synchroniser" Command="{Binding SyncNowCommand}" 
                            HeightRequest="36" Padding="15,0" CornerRadius="8" FontSize="12" />
                </Grid>
            </Border>

            <!-- Recent Activity -->
            <Label Text="Activités Récentes" Style="{StaticResource HeadingLabel}" FontSize="16" />
            <CollectionView ItemsSource="{Binding RecentEvents}" HeightRequest="300">
                <CollectionView.EmptyView>
                    <Label Text="Aucune activité récente." HorizontalTextAlignment="Center" Margin="20" TextColor="{StaticResource TextMuted}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ScanEvent">
                        <Border Style="{StaticResource CardAlt}" Margin="0,5" Padding="12" StrokeShape="RoundRectangle 10">
                             <Grid ColumnDefinitions="Auto, *, Auto">
                                 <Label Text="{Binding EventIcon}" FontSize="24" VerticalOptions="Center" />
                                 <VerticalStackLayout Grid.Column="1" Margin="15,0" VerticalOptions="Center">
                                     <Label Text="{Binding TagId}" FontFamily="RobotoBold" FontSize="13" MaxLines="1" LineBreakMode="TailTruncation" />
                                     <Label Text="{Binding EventType}" TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                 </VerticalStackLayout>
                                 <Label Grid.Column="2" Text="{Binding TimestampDisplay}" FontSize="10" TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                             </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
